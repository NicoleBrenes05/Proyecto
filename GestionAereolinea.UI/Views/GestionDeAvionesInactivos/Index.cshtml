@using GestionAereolinea.Model
@model IEnumerable<GestionAereolinea.Model.Avion>

@{
    ViewData["Title"] = "Lista de Aviones Inactivos";
}

<h1 class="titulo-sistema mb-4">Administración de Aviones Inactivos</h1>

<div class="table-responsive">
    <table class="table table-hover table-bordered bg-white" style="opacity: 0.95;">
        <thead class="table-primary">
            <tr>
                <th>@Html.DisplayNameFor(model => model.First().Id)</th>
                <th>@Html.DisplayNameFor(model => model.First().Nombre)</th>
                <th>@Html.DisplayNameFor(model => model.First().Modelo)</th>
                <th>@Html.DisplayNameFor(model => model.First().Capacidad)</th>
                <th>Aerolínea</th>
                <th>Estado</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td>@item.Nombre</td>
                        <td>@item.Modelo</td>
                        <td>@item.Capacidad</td>
                        <td>@(item.Aerolinea?.Nombre ?? "Sin asignar")</td>
                        <td><span class="badge bg-danger">Inactivo</span></td>
                        <td>
                            @Html.ActionLink("Editar", "Edit", new { id = item.Id }, new { @class = "btn btn-warning btn-sm me-1" }) |
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center">No hay aviones inactivos</td>
                </tr>
            }
        </tbody>
    </table>
</div>