@model IEnumerable<GestionAereolinea.Model.Aerolinea>

@{
    ViewData["Title"] = "Lista de Aerolíneas";
}

<h1 class="titulo-sistema mb-4">Administración de Aerolíneas</h1>


<p>
    <a asp-action="Create" class="btn btn-success">Registrar Aerolínea</a>
</p>


<div class="table-responsive">
    <table class="table table-hover table-bordered bg-white" style="opacity: 0.95;">
        <thead class="table-primary">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Id)</th>
                <th>@Html.DisplayNameFor(model => model.Nombre)</th>
                <th>@Html.DisplayNameFor(model => model.Telefono)</th>
                <td>@Html.DisplayNameFor(model => model.Codigo)</td>
                <td>@Html.DisplayNameFor(model => model.PaísOrigen)</td>
                <th>Aviones</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Id)</td>
                    <td>@Html.DisplayFor(modelItem => item.Nombre)</td>
                    <td>@Html.DisplayFor(modelItem => item.Telefono)</td>
                    <td>@Html.DisplayFor(modelItem => item.Codigo)</td>
                    <td>@Html.DisplayFor(modelItem => item.PaísOrigen)</td>
                    <td>@(item.Aviones != null ? item.Aviones.Count : 0)</td>
                    <td>
                        @Html.ActionLink("Editar", "Edit", new { id = item.Id }, new { @class = "btn btn-primary btn-sm me-1" }) |
                        @Html.ActionLink("Detalles", "Details", new { id = item.Id }, new { @class = "btn btn-info btn-sm me-1" }) |
                        @Html.ActionLink("Eliminar", "Delete", new { id = item.Id }, new { @class = "btn btn-danger btn-sm" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>